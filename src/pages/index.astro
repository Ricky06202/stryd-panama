---
import Layout from '../layouts/Layout.astro'
import { buttonVariants } from '@/components/ui/button'
import { Card, CardContent } from '@/components/ui/card'
import { ArrowRight, Zap, TrendingUp, Target } from 'lucide-react'
import heroBackground from '../assets/hero_background.png'
import { getDb } from '@/db/client'
import { userReviews, users } from '@/db/schema'
import { eq, desc } from 'drizzle-orm'
import { ReviewsCarousel } from '@/components/ReviewsCarousel'

import { sql } from 'drizzle-orm'

const db = getDb(Astro.locals.runtime.env.DB)

if (!Astro.locals.runtime.env.DB) {
  console.error('CRITICAL: Astro.locals.runtime.env.DB is UNDEFINED')
}

const reviews = (
  await db
    .select({
      id: userReviews.id,
      content: userReviews.content,
      createdAt: userReviews.createdAt,
      authorName: users.fullName,
      authorPhoto: users.photoUrl,
    })
    .from(userReviews)
    .innerJoin(users, eq(userReviews.userId, users.id))
    .orderBy(sql`RANDOM()`)
    .limit(10)
    .all()
).map((r) => ({
  ...r,
  createdAt: r.createdAt ? r.createdAt.toISOString() : new Date().toISOString(),
}))
---

<Layout title="Stryd Panama | Entrena con Ciencia, Corre con Potencia">
  <div class="bg-black">
    {/* Hero Section */}
    <section
      class="relative min-h-[700px] flex items-center justify-center overflow-hidden"
    >
      {/* Background Image */}
      <div
        class="absolute inset-0 bg-cover bg-center"
        style={`background-image: url(${heroBackground.src})`}
      >
      </div>

      {/* Dark overlay for better text readability */}
      <div class="absolute inset-0 bg-black/60"></div>

      <div class="relative z-10 text-center text-white max-w-6xl px-4 py-20">
        <h1
          class="text-6xl md:text-8xl font-bold mb-8 drop-shadow-2xl leading-tight"
        >
          Entrena con Ciencia,<br />
          <span
            class="text-transparent bg-clip-text bg-linear-to-r from-orange-500 to-yellow-500"
          >
            Corre con Potencia
          </span>
        </h1>

        <p
          class="text-2xl md:text-3xl mb-12 text-gray-100 drop-shadow-lg font-light"
        >
          El primer equipo de running en Panamá que entrena con tecnología Stryd
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/unete"
            class={buttonVariants({
              variant: 'default',
              size: 'lg',
              className:
                'font-bold shadow-xl shadow-orange-500/20 text-lg px-8 py-6',
            })}
          >
            Únete al Equipo
            <ArrowRight className="ml-2 h-6 w-6" />
          </a>
          <a
            href="/strydboard"
            class={buttonVariants({
              variant: 'outline',
              size: 'lg',
              className:
                'border-2 border-orange-500 text-orange-500 hover:bg-orange-500 hover:text-black font-bold bg-black/50 backdrop-blur-sm text-lg px-8 py-6',
            })}
          >
            StrydBoard
          </a>
        </div>
      </div>
    </section>

    {/* Why Stryd Section */}
    <section class="py-20 relative overflow-hidden">
      <div
        class="absolute inset-0 bg-linear-to-b from-black via-gray-900 to-black"
      >
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold mb-4 text-white">
            ¿Por Qué <span
              class="text-transparent bg-clip-text bg-linear-to-r from-orange-500 to-yellow-500"
              >Stryd</span
            >?
          </h2>
          <p class="text-xl text-gray-400">
            La tecnología que revoluciona el running
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <Card
            className="bg-gray-900/50 border-orange-500/30 hover:border-orange-500 transition-all duration-300 backdrop-blur-sm border"
          >
            <CardContent className="p-8 text-center">
              <div
                class="bg-linear-to-br from-orange-500 to-yellow-500 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg shadow-orange-500/50"
              >
                <Zap className="h-10 w-10 text-black" />
              </div>
              <h3 class="text-2xl font-bold mb-4 text-white">Potencia Real</h3>
              <p class="text-gray-400 leading-relaxed">
                Mide tu esfuerzo exacto en watts, sin importar el terreno, clima
                o condiciones. La única métrica que nunca miente.
              </p>
            </CardContent>
          </Card>

          <Card
            className="bg-gray-900/50 border-orange-500/30 hover:border-orange-500 transition-all duration-300 backdrop-blur-sm border"
          >
            <CardContent className="p-8 text-center">
              <div
                class="bg-linear-to-br from-orange-500 to-yellow-500 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg shadow-orange-500/50"
              >
                <Target className="h-10 w-10 text-black" />
              </div>
              <h3 class="text-2xl font-bold mb-4 text-white">
                Precisión Total
              </h3>
              <p class="text-gray-400 leading-relaxed">
                El ritmo varía con el viento y pendiente. La frecuencia cardíaca
                tarda en responder. La potencia es instantánea y precisa.
              </p>
            </CardContent>
          </Card>

          <Card
            className="bg-gray-900/50 border-orange-500/30 hover:border-orange-500 transition-all duration-300 backdrop-blur-sm border"
          >
            <CardContent className="p-8 text-center">
              <div
                class="bg-linear-to-br from-orange-500 to-yellow-500 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg shadow-orange-500/50"
              >
                <TrendingUp className="h-10 w-10 text-black" />
              </div>
              <h3 class="text-2xl font-bold mb-4 text-white">
                Resultados Comprobados
              </h3>
              <p class="text-gray-400 leading-relaxed">
                Planes personalizados basados en tu potencia crítica y reserva
                de velocidad. Ciencia que funciona.
              </p>
            </CardContent>
          </Card>
        </div>
      </div>
    </section>

    {/* Reviews Carousel Section */}
    {
      reviews.length > 0 && (
        <section class="py-24 bg-black relative">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-from)_0%,_transparent_70%)] from-orange-500/10 to-transparent opacity-50" />
          <div class="relative z-10 max-w-7xl mx-auto px-4">
            <div class="text-center mb-16">
              <h2 class="text-4xl md:text-5xl font-black mb-4 text-white uppercase tracking-tighter">
                Lo que dicen nuestros{' '}
                <span class="text-orange-500">Atletas</span>
              </h2>
              <p class="text-gray-500 font-bold uppercase tracking-[0.2em] text-sm">
                Review real de atletas Stryd Panama
              </p>
            </div>
            <ReviewsCarousel reviews={reviews} client:load />
          </div>
        </section>
      )
    }

    {/* CTA Section */}
    <section class="py-20 relative overflow-hidden">
      <div
        class="absolute inset-0 bg-linear-to-r from-orange-500 to-yellow-500"
      >
      </div>
      <div class="absolute inset-0 opacity-10">
        <svg
          class="w-full h-full opacity-30"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <pattern
              id="circuit"
              x="0"
              y="0"
              width="200"
              height="200"
              patternUnits="userSpaceOnUse"
            >
              <line
                x1="0"
                y1="50"
                x2="80"
                y2="50"
                stroke="black"
                stroke-width="2"></line>
              <line
                x1="120"
                y1="50"
                x2="200"
                y2="50"
                stroke="black"
                stroke-width="2"></line>
              <line
                x1="80"
                y1="20"
                x2="80"
                y2="80"
                stroke="black"
                stroke-width="2"></line>
              <line
                x1="120"
                y1="20"
                x2="120"
                y2="80"
                stroke="black"
                stroke-width="2"></line>
              <circle cx="80" cy="50" r="4" fill="black"></circle>
              <circle cx="120" cy="50" r="4" fill="black"></circle>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#circuit)"></rect>
        </svg>
      </div>

      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-4xl md:text-5xl font-bold mb-6 text-black">
          ¿Listo para Entrenar Diferente?
        </h2>
        <p class="text-xl md:text-2xl mb-10 text-black/80">
          Descubre cómo la potencia puede transformar tu carrera
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <a
            href="/strydboard"
            class={buttonVariants({
              variant: 'secondary',
              size: 'lg',
              className: 'font-bold text-lg px-8 py-6 shadow-xl',
            })}
          >
            Ver StrydBoard
            <ArrowRight className="ml-2 h-5 w-5" />
          </a>
          <a
            href="/calendario"
            class={buttonVariants({
              variant: 'outline',
              size: 'lg',
              className:
                'border-2 border-black text-black hover:bg-black hover:text-white font-bold text-lg px-8 py-6',
            })}
          >
            Calendario de Entrenos
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

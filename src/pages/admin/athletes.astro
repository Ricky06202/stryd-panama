---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { getDb } from '../../db/client'
import { users } from '../../db/schema'
import { eq, desc } from 'drizzle-orm'

const runtime = Astro.locals.runtime
const db = getDb(runtime.env.DB)

// Obtener todos los atletas aprobados (isMember = true)
const athletesRaw = await db
  .select()
  .from(users)
  .where(eq(users.isMember, true))
  .orderBy(desc(users.createdAt))
  .all()

// Sanitizar datos para evitar DevalueError
const athletes = athletesRaw.map((athlete) => ({
  ...athlete,
  createdAt: athlete.createdAt
    ? new Date(athlete.createdAt).toLocaleDateString('es-PA')
    : 'N/A',
}))
---

<AdminLayout title="Gestión de Atletas">
  <div class="mb-8 flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold text-foreground">Gestión de Atletas</h1>
      <p class="text-muted-foreground mt-2">
        Visualiza y gestiona la información de todos los miembros del equipo.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      athletes.length === 0 ? (
        <div class="col-span-full bg-card rounded-xl border border-border p-12 text-center text-muted-foreground">
          No hay atletas aprobados todavía.
        </div>
      ) : (
        athletes.map((athlete) => (
          <div class="bg-card rounded-xl border border-border overflow-hidden shadow-sm hover:shadow-md transition group">
            <div class="aspect-video bg-muted relative overflow-hidden">
              {athlete.photoUrl ? (
                <img
                  src={athlete.photoUrl}
                  alt={athlete.fullName}
                  class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-muted-foreground">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-12 w-12 opacity-20"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    />
                  </svg>
                </div>
              )}
              <div class="absolute top-3 right-3">
                <span class="px-2 py-1 bg-green-500 text-white text-[10px] font-bold uppercase rounded shadow-sm">
                  Miembro
                </span>
              </div>
            </div>

            <div class="p-5">
              <h3 class="text-lg font-bold text-foreground mb-1">
                {athlete.fullName}
              </h3>
              <p class="text-sm text-muted-foreground mb-4 flex items-center gap-1">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  />
                </svg>
                {athlete.email}
              </p>

              <div class="grid grid-cols-2 gap-3 mb-5">
                <div class="bg-muted/50 rounded-lg p-2 text-center">
                  <p class="text-[10px] text-muted-foreground uppercase font-bold">
                    Cédula
                  </p>
                  <p class="text-xs font-medium">{athlete.idCard}</p>
                </div>
                <div class="bg-muted/50 rounded-lg p-2 text-center">
                  <p class="text-[10px] text-muted-foreground uppercase font-bold">
                    Teléfono
                  </p>
                  <p class="text-xs font-medium">{athlete.phone || 'N/A'}</p>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-3">
                <button
                  data-athlete-id={athlete.id}
                  data-athlete-name={athlete.fullName}
                  data-athlete-email={athlete.email}
                  data-athlete-phone={athlete.phone}
                  data-athlete-idcard={athlete.idCard}
                  class="edit-btn py-2 bg-muted hover:bg-muted/80 text-foreground text-center text-sm font-bold rounded-lg transition border border-border flex items-center justify-center gap-2"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
                      <path d="m15 5 4 4" />
                    </>
                  </svg>
                  Editar
                </button>
                <button
                  data-athlete-id={athlete.id}
                  data-athlete-name={athlete.fullName}
                  class="delete-btn py-2 bg-red-500/10 hover:bg-red-500/20 text-red-500 text-center text-sm font-bold rounded-lg transition border border-red-500/20 flex items-center justify-center gap-2"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M3 6h18" />
                      <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" />
                      <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" />
                      <line x1="10" x2="10" y1="11" y2="17" />
                      <line x1="14" x2="14" y1="11" y2="17" />
                    </>
                  </svg>
                  Borrar
                </button>
              </div>

              <a
                href={`/admin/athletes/${athlete.id}`}
                class="block w-full mt-3 py-2 bg-primary hover:bg-primary/90 text-primary-foreground text-center text-sm font-bold rounded-lg transition"
              >
                Ver Perfil Completo
              </a>
            </div>
          </div>
        ))
      )
    }
  </div>

  <!-- Modal de Edición -->
  <div
    id="edit-modal"
    class="fixed inset-0 bg-background/80 backdrop-blur-sm z-50 hidden items-center justify-center p-4"
  >
    <div
      class="bg-card border border-border rounded-xl shadow-lg max-w-md w-full overflow-hidden"
    >
      <div class="p-6 border-b border-border flex justify-between items-center">
        <h2 class="text-xl font-bold">Editar Atleta</h2>
        <button
          id="close-modal"
          class="text-muted-foreground hover:text-foreground"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
          >
        </button>
      </div>
      <form id="edit-form" class="p-6 space-y-4">
        <input type="hidden" id="edit-id" name="id" />
        <div>
          <label
            class="text-xs font-bold uppercase text-muted-foreground mb-1 block"
            >Nombre Completo</label
          >
          <input
            type="text"
            id="edit-name"
            name="fullName"
            class="w-full bg-muted border border-border rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none"
            required
          />
        </div>
        <div>
          <label
            class="text-xs font-bold uppercase text-muted-foreground mb-1 block"
            >Email</label
          >
          <input
            type="email"
            id="edit-email"
            name="email"
            class="w-full bg-muted border border-border rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none"
            required
          />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label
              class="text-xs font-bold uppercase text-muted-foreground mb-1 block"
              >Cédula</label
            >
            <input
              type="text"
              id="edit-idcard"
              name="idCard"
              class="w-full bg-muted border border-border rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none"
              required
            />
          </div>
          <div>
            <label
              class="text-xs font-bold uppercase text-muted-foreground mb-1 block"
              >Teléfono</label
            >
            <input
              type="text"
              id="edit-phone"
              name="phone"
              class="w-full bg-muted border border-border rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none"
            />
          </div>
        </div>
        <div class="pt-4 flex gap-3">
          <button
            type="button"
            id="cancel-edit"
            class="flex-1 py-2 bg-muted hover:bg-muted/80 text-foreground font-bold rounded-lg transition border border-border"
          >
            Cancelar
          </button>
          <button
            type="submit"
            class="flex-1 py-2 bg-primary hover:bg-primary/90 text-primary-foreground font-bold rounded-lg transition"
          >
            Guardar Cambios
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Deletion Logic
    const deleteButtons = document.querySelectorAll('.delete-btn')
    deleteButtons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-athlete-id')
        const name = btn.getAttribute('data-athlete-name')

        if (
          confirm(
            `¿Estás seguro de que deseas eliminar a ${name}? Esta acción no se puede deshacer.`,
          )
        ) {
          try {
            const res = await fetch('/api/admin/athletes', {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: parseInt(id!) }),
            })

            if (res.ok) {
              window.location.reload()
            } else {
              alert('Error al eliminar atleta')
            }
          } catch (e) {
            console.error(e)
            alert('Error al procesar la solicitud')
          }
        }
      })
    })

    // Edit Logic
    const modal = document.getElementById('edit-modal')
    const editForm = document.getElementById('edit-form') as HTMLFormElement
    const editButtons = document.querySelectorAll('.edit-btn')
    const closeModal = document.getElementById('close-modal')
    const cancelEdit = document.getElementById('cancel-edit')

    const openModal = (data: any) => {
      ;(document.getElementById('edit-id') as HTMLInputElement).value = data.id
      ;(document.getElementById('edit-name') as HTMLInputElement).value =
        data.name
      ;(document.getElementById('edit-email') as HTMLInputElement).value =
        data.email
      ;(document.getElementById('edit-idcard') as HTMLInputElement).value =
        data.idcard
      ;(document.getElementById('edit-phone') as HTMLInputElement).value =
        data.phone || ''
      modal?.classList.remove('hidden')
      modal?.classList.add('flex')
    }

    const hideModal = () => {
      modal?.classList.add('hidden')
      modal?.classList.remove('flex')
    }

    editButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const data = {
          id: btn.getAttribute('data-athlete-id'),
          name: btn.getAttribute('data-athlete-name'),
          email: btn.getAttribute('data-athlete-email'),
          phone: btn.getAttribute('data-athlete-phone'),
          idcard: btn.getAttribute('data-athlete-idcard'),
        }
        openModal(data)
      })
    })

    closeModal?.addEventListener('click', hideModal)
    cancelEdit?.addEventListener('click', hideModal)
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) hideModal()
    })

    editForm?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const formData = new FormData(editForm)
      const data = {
        id: parseInt(formData.get('id') as string),
        fullName: formData.get('fullName'),
        email: formData.get('email'),
        idCard: formData.get('idCard'),
        phone: formData.get('phone'),
      }

      try {
        const res = await fetch('/api/admin/athletes', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        })

        if (res.ok) {
          window.location.reload()
        } else {
          alert('Error al actualizar atleta')
        }
      } catch (e) {
        console.error(e)
        alert('Error al procesar la solicitud')
      }
    })
  </script>
</AdminLayout>
```
